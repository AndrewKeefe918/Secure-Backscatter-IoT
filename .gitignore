# For PCBs designed using KiCad: https://www.kicad.org/
# Format documentation: https://kicad.org/help/file-formats/

# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*-cache*
*-bak
*-bak*
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Archived Backups (KiCad 6.0)
**/*-backups/*.zip

# Local project settings
*.kicad_prl

# Python virtual environment
.venv/
.venv-*/
.vendor/
.theia/
.vscode/
vcpkg_installed/
volk-gr/
gnuradio/
# Local-only working files (kept out of the repo for now)
archive/
Log/
_driver_tmp/

# CCS / MSP430 build output
Blink LED/Debug/
*.obj
*.d
*.out
*.map

# Captures, screenshots, dumps
*.npz
*.jpg

# Large text copies of vendor PDFs (keep local, not in repo)
msp430_*_readable*.txt
msp430_user_guides_readable_combined.txt
infoA.txt

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

